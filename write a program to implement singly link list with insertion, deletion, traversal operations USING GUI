btn_style = {
    "font": ("Segoe UI", 11, "bold"),
    "bg": "#43A047",
    "fg": "white",
    "activebackground": "#2E7D32",
    "activeforeground": "white",
    "width": 22,
    "height": 2,
    "cursor": "hand2",
    "bd": 0,
}

button_frame = tk.Frame(root, bg="#E8F5E9")
button_frame.pack()


tk.Button(button_frame, text="Insert Beginning",
          command=insert_begin, **btn_style).grid(row=0, column=0, padx=8, pady=8)

tk.Button(button_frame, text="Insert End",
          command=insert_end, **btn_style).grid(row=0, column=1, padx=8, pady=8)

tk.Button(button_frame, text="Insert Position",
          command=insert_pos, **btn_style).grid(row=1, column=0, padx=8, pady=8)

tk.Button(button_frame, text="Delete Beginning",
          command=delete_begin, **btn_style).grid(row=1, column=1, padx=8, pady=8)

tk.Button(button_frame, text="Delete End",
          command=delete_end, **btn_style).grid(row=2, column=0, padx=8, pady=8)

tk.Button(button_frame, text="Delete Position",
          command=delete_pos, **btn_style).grid(row=2, column=1, padx=8, pady=8)

tk.Button(button_frame, text="Display List",
          command=update_display, **btn_style).grid(row=3, column=0, columnspan=2, pady=10)


tk.Button(
    root,
    text="EXIT",
    command=root.destroy,
    font=("Segoe UI", 12, "bold"),
    bg="#E53935",
    fg="white",
    activebackground="#C62828",
    width=20,
    cursor="hand2",
).pack(pady=20)

root.mainloop()
