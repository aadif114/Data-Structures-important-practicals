import tkinter as tk
from tkinter import messagebox

class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

class SinglyLinkedList:
    def __init__(self):
        self.head = None

    def insert_beginning(self, data):
        new_node = Node(data)
        new_node.next = self.head
        self.head = new_node

    def insert_end(self, data):
        new_node = Node(data)

        if self.head is None:
            self.head = new_node
            return

        temp = self.head
        while temp.next:
            temp = temp.next

        temp.next = new_node

    def insert_position(self, data, pos):
        if pos <= 1:
            self.insert_beginning(data)
            return True

        temp = self.head
        count = 1

        while temp and count < pos - 1:
            temp = temp.next
            count += 1

        if temp is None:
            return False

        new_node = Node(data)
        new_node.next = temp.next
        temp.next = new_node
        return True

    def delete_beginning(self):
        if self.head is None:
            return False

        self.head = self.head.next
        return True

    def delete_end(self):
        if self.head is None:
            return False

        if self.head.next is None:
            self.head = None
            return True

        temp = self.head
        while temp.next.next:
            temp = temp.next

        temp.next = None
        return True

    def delete_position(self, pos):
        if self.head is None:
            return False

        if pos == 1:
            return self.delete_beginning()

        temp = self.head
        count = 1

        while temp.next and count < pos - 1:
            temp = temp.next
            count += 1

        if temp.next is None:
            return False

        temp.next = temp.next.next
        return True

    def display(self):
        if self.head is None:
            return "NULL"

        temp = self.head
        result = "HEAD → "

        while temp:
            result += f"[{temp.data}]"

            if temp.next:
                result += " → "

            temp = temp.next

        result += " → NULL"
        return result


sll = SinglyLinkedList()

root = tk.Tk()
root.title("Singly Linked List Visualizer")
root.geometry("850x700")
root.configure(bg="#E8F5E9")


title = tk.Label(
    root,
    text="SINGLY LINKED LIST VISUALIZER",
    font=("Segoe UI", 22, "bold"),
    bg="#2E7D32",
    fg="white",
    pady=15,
)

title.pack(fill="x")


frame = tk.Frame(root, bg="#E8F5E9")
frame.pack(pady=20)

tk.Label(
    frame,
    text="Enter Data",
    font=("Segoe UI", 12, "bold"),
    bg="#E8F5E9",
    fg="#1B5E20",
).grid(row=0, column=0, padx=10, pady=10)

data_entry = tk.Entry(frame, font=("Segoe UI", 13), width=20, justify="center")
data_entry.grid(row=0, column=1)

tk.Label(
    frame,
    text="Position",
    font=("Segoe UI", 12, "bold"),
    bg="#E8F5E9",
    fg="#1B5E20",
).grid(row=1, column=0, padx=10, pady=10)

pos_entry = tk.Entry(frame, font=("Segoe UI", 13), width=20, justify="center")
pos_entry.grid(row=1, column=1)


output = tk.Label(
    root,
    text="Linked List is Empty",
    bg="white",
    fg="#1B5E20",
    font=("Consolas", 15, "bold"),
    width=70,
    height=5,
    relief="solid",
    bd=3,
)

output.pack(pady=20)


def update_display():
    output.config(text=sll.display())


def get_data():
    try:
        return int(data_entry.get())
    except:
        messagebox.showerror("Error", "Please enter a valid integer.")
        return None


def get_position():
    try:
        return int(pos_entry.get())
    except:
        messagebox.showerror("Error", "Please enter a valid position.")
        return None



def insert_begin():
    data = get_data()
    if data is not None:
        sll.insert_beginning(data)
        update_display()


def insert_end():
    data = get_data()
    if data is not None:
        sll.insert_end(data)
        update_display()


def insert_pos():
    data = get_data()
    pos = get_position()

    if data is not None and pos is not None:
        if sll.insert_position(data, pos):
            update_display()
        else:
            messagebox.showerror("Error", "Invalid Position")


def delete_begin():
    if sll.delete_beginning():
        update_display()
    else:
        messagebox.showerror("Error", "List is Empty")


def delete_end():
    if sll.delete_end():
        update_display()
    else:
        messagebox.showerror("Error", "List is Empty")


def delete_pos():
    pos = get_position()

    if pos is not None:
        if sll.delete_position(pos):
            update_display()
        else:
            messagebox.showerror("Error", "Invalid Position")


