import tkinter as tk
from tkinter import ttk, messagebox

stack = []


def update_stack():
    stack_list.delete(0, tk.END)
    for item in reversed(stack):
        stack_list.insert(tk.END, item)

def push():
    value = stack_entry.get()
    if value == "":
        messagebox.showwarning("Warning", "Please enter a value!")
        return

    stack.append(value)
    stack_entry.delete(0, tk.END)
    update_stack()
    result.config(text=f"✔ '{value}' pushed into stack", fg="#2ecc71")

def pop():
    if not stack:
        messagebox.showerror("Error", "Stack Underflow!")
        return

    value = stack.pop()
    update_stack()
    result.config(text=f"✔ Popped: {value}", fg="#e74c3c")

def peek():
    if not stack:
        messagebox.showerror("Error", "Stack is Empty!")
    else:
        result.config(text=f"Top Element: {stack[-1]}", fg="#3498db")

def delimiter():
    expr = expr_entry.get()
    s = []
    pairs = {')':'(', ']':'[', '}':'{'}

    for ch in expr:
        if ch in "([{":
            s.append(ch)
        elif ch in ")]}":
            if not s or s.pop()!=pairs[ch]:
                result.config(text="❌ Delimiters NOT Balanced", fg="red")
                return

    if not s:
        result.config(text="✅ Delimiters Balanced", fg="green")
    else:
        result.config(text="❌ Delimiters NOT Balanced", fg="red")

def prefix_postfix():
    prefix = expr_entry.get()
    s = []

    try:
        for ch in reversed(prefix):
            if ch.isalnum():
                s.append(ch)
            else:
                a = s.pop()
                b = s.pop()
                s.append(a+b+ch)

        result.config(text="Postfix : " + s[-1], fg="#8e44ad")

    except:
        result.config(text="Invalid Prefix Expression", fg="red")

def evaluate():
    prefix = expr_entry.get()
    s = []

    try:
        for ch in reversed(prefix):
            if ch.isdigit():
                s.append(int(ch))
            else:
                a = s.pop()
                b = s.pop()

                if ch == '+':
                    s.append(a+b)
                elif ch == '-':
                    s.append(a-b)
                elif ch == '*':
                    s.append(a*b)
                elif ch == '/':
                    s.append(a//b)

        result.config(text="Result = " + str(s[-1]), fg="#16a085")

    except:
        result.config(text="Invalid Expression", fg="red")


root = tk.Tk()
root.title("Stack Visualizer")
root.geometry("750x650")
root.configure(bg="#1e1e2f")
root.resizable(False, False)

style = ttk.Style()
style.theme_use("clam")

