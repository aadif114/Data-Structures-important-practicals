frame3.pack(padx=20,pady=10,fill="x")

expr_entry = ttk.Entry(frame3,font=("Segoe UI",12),width=40)
expr_entry.grid(row=0,column=0,columnspan=3,pady=10)

ttk.Button(frame3,text="Delimiter Match",
           command=delimiter).grid(row=1,column=0,padx=5,pady=10)

